# Port for the Socket.io server to listen on
PORT=3000

# Shared secret — must match LSG_SOCKETIO_SECRET in wp-config.php
# Generate a strong random value: openssl rand -hex 32
LSG_SECRET=change-me-to-a-long-random-secret

# Allowed CORS origin (your WordPress site URL, or * for any)
CORS_ORIGIN=https://your-wordpress-site.com

# Ensure consistent line endings across platforms
* text=auto eol=lf

# PHP files — treat as text
*.php text eol=lf

# JS files — treat as text
*.js text eol=lf

# Markdown — treat as text
*.md text eol=lf

# Binary files — do not diff or modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
